ORDER BY Sales DESC;</sql><sql name="SQL 2">SELECT * FROM cars 
WHERE Type = 'Innova'
ORDER BY Area, Sales;</sql><sql name="SQL 3">SELECT Merk, SUM(Sales) FROM cars 
GROUP BY Merk;</sql><sql name="SQL 4">SELECT Type, SUM(Sales) FROM cars
GROUP BY Type
ORDER BY SUM(Sales) DESC
LIMIT 3;</sql><sql name="SQL 5">SELECT Type, SUM(Sales) FROM cars
WHERE Merk = 'Toyota' OR Merk = 'Honda'
GROUP BY Type
ORDER BY SUM(Sales) DESC
LIMIT 1;</sql><sql name="SQL 6*">SELECT Area, 
SUM(Sales)- SUM(Congs) AS 'Gross Profit',
0.88 *(SUM(Sales)- SUM(Congs)) AS 'Nett Profit'
FROM cars
GROUP BY Area
ORDER BY SUM(Sales)- SUM(Congs) DESC;</sql><sql name="SQL 7*">WITH Profit AS(
	SELECT Area, 
	SUM(Sales)- SUM(Congs) AS Gross
	FROM cars
	GROUP BY Area
	ORDER BY Gross DESC
) SELECT Area, Gross, 0.88*Gross AS 'Nett' FROM Profit;</sql><current_tab id="6"/></tab_sql></sqlb_project>
