FROM products;</sql><sql name="SQL 2">SELECT printf(&quot;%.2f&quot;, AVG(price)) AS &quot;Avg Price&quot;
FROM products;</sql><sql name="SQL 3">SELECT * FROM sales;</sql><sql name="SQL 4">SELECT nama_produk, harga, jumlah FROM sales;</sql><sql name="SQL 5">SELECT * FROM sales WHERE kategori = &quot;Skincare&quot;;</sql><sql name="SQL 6">SELECT * FROM sales 
WHERE kota = &quot;Jakarta&quot; and jumlah &gt; 2;</sql><sql name="SQL 7">SELECT nama_produk, harga, jumlah, harga*jumlah as
&quot;total revenue&quot; from sales;</sql><sql name="SQL 8">SELECT sum(jumlah) as &quot;total&quot; FROM sales;</sql><sql name="SQL 9">SELECT kategori, sum(jumlah) from sales
GROUP by kategori;</sql><sql name="SQL 10*">SELECT kota, harga * jumlah AS &quot;revenue&quot; FROM sales
GROUP BY kota;</sql><sql name="SQL 11*">SELECT *, harga*jumlah AS &quot;revenue&quot; FROM sales
ORDER BY harga*jumlah DESC LIMIT 1;</sql><sql name="SQL 12*">with summary as (
select avg(harga) as average from sales
) select * from sales, summary 
where sales.harga &gt; summary.average;</sql><current_tab id="11"/></tab_sql></sqlb_project>
