WHERE Merk='Toyota' OR Merk='Suzuki';</sql><sql name="SQL 5*">SELECT * FROM cars 
WHERE Merk = 'Toyota' 
AND Sales &gt; 500000000 AND Area = 'Veteran';</sql><sql name="SQL 6*">SELECT * FROM cars
WHERE Merk = 'Toyota' AND Sold &gt; 5 AND Area = 'Veteran';</sql><sql name="SQL 7*">SELECT * FROM cars ORDER BY Area DESC, Sales;</sql><sql name="SQL 8*">SELECT Merk, AVG(Sales) AS 'Rata-rata Penjualan', 
SUM(Sold) AS 'Jumlah Unit Terjual'
FROM cars
GROUP BY Merk;</sql><sql name="SQL 9*">SELECT Area, AVG(Sales), SUM(Sold) FROM cars
GROUP BY Area ORDER BY AVG(Sales) DESC LIMIT 1;</sql><sql name="SQL 10*">SELECT Type, SUM(Sold) AS 'Unit Terjual' FROM cars
GROUP BY Type ORDER BY SUM(Sold) DESC
LIMIT 3;</sql><current_tab id="9"/></tab_sql></sqlb_project>
