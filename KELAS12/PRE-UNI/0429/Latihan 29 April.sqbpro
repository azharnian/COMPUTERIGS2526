FROM sales
GROUP BY kota;</sql><sql name="SQL 3*">SELECT *, harga*jumlah AS 'revenue'
FROM sales ORDER BY harga*jumlah DESC 
LIMIT 1;</sql><sql name="SQL 4*">WITH summary AS (
	SELECT AVG(harga) AS average
	FROM sales
) SELECT * FROM sales, summary
WHERE sales.harga &gt; summary.average;</sql><current_tab id="3"/></tab_sql></sqlb_project>
