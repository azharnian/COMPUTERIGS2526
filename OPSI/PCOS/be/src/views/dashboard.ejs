<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Realtime</title>
    <link rel="stylesheet" href="/public/dashboard/dashboard.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <script>
        window.__DASHBOARD__ = {
            initialTanks: <%- JSON.stringify(tanks) %>,
            tankIds: <%- JSON.stringify(tankIds) %>
        };
    </script>

    <div class="container">
        <%- include('dashboard/header') %>
        <%- include('dashboard/tank-list', { tanks }) %>
        <%- include('dashboard/sidebar', { tankId, tankIds }) %>
    </div>

    <script src="/public/dashboard/dashboard.js"></script>
</body>
</html>
